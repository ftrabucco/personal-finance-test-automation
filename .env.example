# local | staging | prod
TEST_ENV=local

# Frontend URL
E2E_BASE_URL=http://localhost:3001
E2E_PROD_BASE_URL=https://personal-finance-frontend-pied.vercel.app

# API URL
E2E_API_URL=http://localhost:3030/api
E2E_PROD_API_URL=https://unfortunately-tide-feb-manor.trycloudflare.com/api

# Dedicated test user. Use a safe read-only user for production smoke.
E2E_USER_EMAIL=e2e@example.com
E2E_USER_PASSWORD=change-me

# Safety guard. Destructive tests should require this to be true.
ALLOW_DESTRUCTIVE_TESTS=false
